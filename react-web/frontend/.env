# ─── Configuração da API ──────────────────────────────────────────────────────
# Deixe VITE_API_URL em branco para detecção automática:
#   - GitHub Codespaces → URL pública gerada automaticamente
#   - Ambiente local     → http://localhost:8080/api/v1
#
# Preencha apenas se quiser sobrescrever a detecção automática:
VITE_API_URL=

# ─── Portas (opcionais) ────────────────────────────────────────────────────────
# Porta do servidor de desenvolvimento Vite (padrão: 5173)
# VITE_DEV_PORT=5173

# Porta do servidor de preview (padrão: 4173)
# VITE_PREVIEW_PORT=4173

# Porta do backend Spring Boot (padrão: 8080)
# VITE_BACKEND_PORT=8080

