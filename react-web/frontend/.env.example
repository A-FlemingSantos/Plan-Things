# ─── Configuração da API ──────────────────────────────────────────────────────
# Deixe em branco para detecção automática (Codespaces ou localhost).
# Preencha apenas se precisar apontar para um backend em endereço customizado.
#
# Exemplos:
#   Desenvolvimento local:  VITE_API_URL=http://localhost:8080/api/v1
#   Codespaces (manual):    VITE_API_URL=https://<nome>-8080.app.github.dev/api/v1
#   Produção:               VITE_API_URL=https://api.seudominio.com/api/v1
VITE_API_URL=

# ─── Portas (opcionais) ────────────────────────────────────────────────────────
# VITE_DEV_PORT=5173
# VITE_PREVIEW_PORT=4173
# VITE_BACKEND_PORT=8080
