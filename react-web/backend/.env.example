# Opcional: use este arquivo apenas se quiser rodar com SQL Server em vez do fallback local H2.
DB_URL=jdbc:sqlserver://<host>:1433;databaseName=<database>;encrypt=true;trustServerCertificate=true
DB_USERNAME=<username>
DB_PASSWORD=<password>

# Opcional
SERVER_PORT=8080

# CORS (produção): inclua a origem do frontend hospedado no Somee, separando por vírgula quando houver mais de uma.
APP_CORS_ALLOWED_ORIGINS=https://<seu-frontend>.somee.com

# Sessão HTTP (quando frontend e backend ficam em domínios diferentes)
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_SECURE=true
